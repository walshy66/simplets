# Auth mode: "dev" trusts the X-STS-User header (local only); "clerk" verifies
# Clerk session JWTs on the Authorization header.
STS_AUTH_MODE=dev

# Required when STS_AUTH_MODE=clerk
CLERK_ISSUER=
# Optional comma-separated list of allowed azp origins
CLERK_AUTHORIZED_PARTIES=

# Comma-separated user ids treated as STS platform admins
STS_PLATFORM_ADMINS=platform-admin

# Tenancy
STS_BASE_DOMAIN=simplets.com.au
STS_DEV_WORKSPACE=coachcw
